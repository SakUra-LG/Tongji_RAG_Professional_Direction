# ======================================================
# Tongji-RAG Environment Configuration Template
# 使用说明:
# 1. 复制此文件并重命名为 .env
# 2. 填入真实的 API Key 和自定义密码
# 3. 确保 .env 文件被加入 .gitignore
# ======================================================

# --- 项目基础配置 ---
PROJECT_NAME=tongji_rag

# --- LLM 模型服务 (阿里云百炼 / DashScope) ---
# 必填: 你的阿里云 API Key (sk-开头)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# --- 安全与鉴权 (JWT) ---
# 生产环境请务必修改为一个长随机字符串 (可以使用 `openssl rand -hex 32` 生成)
JWT_SECRET_KEY=change_this_to_a_secure_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost,http://127.0.0.1

# --- Redis 配置 ---
# 如果在 Docker 内运行，HOST 填服务名 'redis'；如果在本地调试，填 'localhost'
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_secret

# --- MySQL 配置 ---
# 如果在 Docker 内运行，HOST 填服务名 'mysql'
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=tongji_rag_db
MYSQL_USER=rag_user
MYSQL_PASSWORD=change_me_mysql_user_secret

# MySQL Root 密码 (仅用于 Docker 容器初始化)
MYSQL_ROOT_PASSWORD=change_me_mysql_root_secret

# --- Milvus 向量数据库配置 ---
# 如果在 Docker 内运行，HOST 填服务名 'milvus-standalone'
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_secret

# --- 宿主机端口，可按需修改 ---
FRONTEND_PORT=80
BACKEND_PORT=8000
ATTU_PORT=8001
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
